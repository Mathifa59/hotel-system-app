POSTGRES_USER=hotel
POSTGRES_PASSWORD=change_me
POSTGRES_DB=hotel

DATABASE_URL=postgresql+psycopg2://hotel:change_me@db:5432/hotel
REDIS_URL=redis://redis:6379/0

JWT_SECRET=change_this_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=720

ADMIN_NAME=Admin
ADMIN_EMAIL=admin@hotel.com
ADMIN_PASSWORD=change_me_admin

# Solo se usa en producción (docker-compose.prod.yml) — el dominio o
# subdominio que apunta por DNS a este servidor. Caddy emite el certificado
# HTTPS automáticamente para este nombre.
DOMAIN=gestion.tudominio.com
