# ───── Secretos / entorno (NUNCA subir) ─────
.env
.env.*
!.env.example

# Certificado local del antivirus (Kaspersky hace TLS interception) — solo
# necesario en esta máquina de desarrollo para que npm pueda instalar dentro
# de Docker. No tiene sentido en otra máquina ni en producción.
kaspersky-ca.pem

# Override de Docker Compose solo para esta máquina (monta el certificado de
# Kaspersky en el frontend para que pueda bajar Google Fonts en dev).
docker-compose.override.yml

# ───── Python / backend ─────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ───── Node / frontend ─────
node_modules/
.next/
out/
build/
*.tsbuildinfo
next-env.d.ts
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ───── Datos locales / respaldos ─────
# Los datos de Postgres viven en el volumen de Docker (pg_data), no en el repo.
# Los respaldos (scripts/backup.sh) tampoco deben subirse a GitHub.
backups/
*.sql
*.dump
*.sqlite3

# ───── Sistema operativo / editor ─────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.pem
